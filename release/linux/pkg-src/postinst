#!/bin/bash
# Настраивает ai-timer-worked после установки .deb: Node.js, роль/БД
# PostgreSQL, миграции, venv таймера, сборка дашборда.
# Выполняется от root (стандартный postinst dpkg).
set -e

APP_DIR=/opt/ai-timer-worked
TIMER_DIR="$APP_DIR/timer"
DASHBOARD_DIR="$APP_DIR/dashboard"

DB_NAME="ai_timer_worked"
DB_ROLE="ai_timer_worked"
DASHBOARD_PORT="3000"

TARGET_USER="${SUDO_USER:-$(logname 2>/dev/null || true)}"

echo ""
echo "=== Настройка ai-timer-worked ==="
echo ""

echo "[1/6] Node.js..."
NEED_NODE_INSTALL=1
if command -v node >/dev/null 2>&1; then
    NODE_MAJOR="$(node -v | sed -E 's/^v([0-9]+).*/\1/')"
    if [ "$NODE_MAJOR" -ge 22 ] 2>/dev/null; then
        NEED_NODE_INSTALL=0
    fi
fi
if [ "$NEED_NODE_INSTALL" -eq 1 ]; then
    echo "  Устанавливаю Node.js 22.x из NodeSource..."
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
        echo "  Ожидание освобождения dpkg lock..."
        sleep 2
    done
    apt-get install -y nodejs
fi

echo "[2/6] PostgreSQL: роль и база данных..."
systemctl enable --now postgresql

ROLE_EXISTS="$(su -s /bin/sh postgres -c "psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname='${DB_ROLE}'\"")"
DB_PASSWORD=""
if [ "$ROLE_EXISTS" = "1" ] && [ -f "$TIMER_DIR/.env" ]; then
    DB_PASSWORD="$(sed -nE "s#^DATABASE_URL=postgresql://${DB_ROLE}:([^@]+)@.*#\1#p" "$TIMER_DIR/.env")"
fi
if [ "$ROLE_EXISTS" = "1" ] && [ -n "$DB_PASSWORD" ]; then
    echo "  Роль ${DB_ROLE} уже существует, пароль переиспользую из timer/.env."
else
    DB_PASSWORD="$(openssl rand -hex 16)"
    if [ "$ROLE_EXISTS" = "1" ]; then
        su -s /bin/sh postgres -c "psql -c \"ALTER ROLE ${DB_ROLE} WITH PASSWORD '${DB_PASSWORD}';\"" >/dev/null
    else
        su -s /bin/sh postgres -c "psql -c \"CREATE ROLE ${DB_ROLE} WITH LOGIN PASSWORD '${DB_PASSWORD}';\"" >/dev/null
    fi
fi

DB_EXISTS="$(su -s /bin/sh postgres -c "psql -tAc \"SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'\"")"
if [ "$DB_EXISTS" != "1" ]; then
    su -s /bin/sh postgres -c "psql -c \"CREATE DATABASE ${DB_NAME} OWNER ${DB_ROLE};\"" >/dev/null
fi

DATABASE_URL="postgresql://${DB_ROLE}:${DB_PASSWORD}@localhost:5432/${DB_NAME}"
DASHBOARD_URL="http://localhost:${DASHBOARD_PORT}"

echo "[3/6] Виртуальное окружение таймера и Python-зависимости..."
python3 -m venv "$TIMER_DIR/.venv" --system-site-packages
"$TIMER_DIR/.venv/bin/pip" install --quiet --upgrade pip
"$TIMER_DIR/.venv/bin/pip" install --quiet -r "$TIMER_DIR/requirements.txt"
chmod +x "$TIMER_DIR/timer.py" "$TIMER_DIR/autostart.sh" "$DASHBOARD_DIR/autostart.sh"

echo "[4/6] .env файлы..."
cat > "$TIMER_DIR/.env" <<EOF
DB_BACKEND=postgres
DATABASE_URL=${DATABASE_URL}
DASHBOARD_URL=${DASHBOARD_URL}
EOF

cat > "$DASHBOARD_DIR/.env" <<EOF
DATABASE_URL=${DATABASE_URL}
PORT=${DASHBOARD_PORT}
EOF

if [ -n "$TARGET_USER" ] && id "$TARGET_USER" >/dev/null 2>&1; then
    chown "$TARGET_USER" "$TIMER_DIR/.env" "$DASHBOARD_DIR/.env"
fi
chmod 600 "$TIMER_DIR/.env" "$DASHBOARD_DIR/.env"

echo "[5/6] Миграции БД..."
"$TIMER_DIR/.venv/bin/python" - "$DATABASE_URL" <<PYEOF
import sys
sys.path.insert(0, "$TIMER_DIR")
import db_backend

applied = db_backend.run_pending_migrations(sys.argv[1])
if applied:
    print(f"  Применены миграции: {', '.join(applied)}")
else:
    print("  Все миграции уже применены.")
PYEOF

echo "[6/6] Установка и сборка дашборда (npm)..."
npm install --prefix "$DASHBOARD_DIR"
npm run build --prefix "$DASHBOARD_DIR"

cat <<MSG

=== ai-timer-worked установлен ===

1. Запустите таймер через меню приложений, либо командой:
   $TIMER_DIR/.venv/bin/python $TIMER_DIR/timer.py

2. Дашборд соберён и настроен на ${DASHBOARD_URL}, но пока не запущен
   и не добавлен в автозапуск — это делается от вашего обычного
   пользователя (не root), выполните:
     bash $TIMER_DIR/autostart.sh
     bash $DASHBOARD_DIR/autostart.sh

   После этого таймер и дашборд запустятся сейчас и будут запускаться
   автоматически при каждом входе в систему. Дашборд также открывается
   из трей-меню таймера: "🌐 Открыть дашборд".

MSG

exit 0
