# Заполняется автоматически мастером первого запуска (см. README).
# DB_BACKEND=supabase|postgres

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- PostgreSQL (прямое подключение) ---
# Строка подключения. Нужна либо как основной способ доступа (DB_BACKEND=postgres),
# либо дополнительно к Supabase — только для автоматических миграций
# (Supabase: Project Settings -> Database -> Connection string).
# Заполняется автоматически install.sh при локальной установке.
DATABASE_URL=

# --- Дашборд ---
# URL локального веб-дашборда (проект dashboard/), открывается пунктом
# меню "Открыть дашборд". Заполняется install.sh.
DASHBOARD_URL=http://localhost:3000
